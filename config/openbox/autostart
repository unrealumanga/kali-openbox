#!/bin/sh
#
# Openbox autostart - PopOS! style, lean and clean
#

# Wait for desktop to be ready
sleep 1

# Set default wallpaper if nitrogen doesn't restore
if [ ! -f "$HOME/.config/nitrogen/bg-saved.cfg" ]; then
    nitrogen --set-zoom-fill /usr/share/backgrounds/offtopic/offtopic-dark.jpg &
else
    nitrogen --restore &
fi

# Compositor with vsync
picom --config ~/.config/picom.conf --vsync &
sleep 0.5

# Keyboard layout
setxkbmap us &
numlockx on &

# Bluetooth
blueman-applet &

# Clipboard manager
xclipmenud &

# Authentication agent
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

# Cursor
xsetroot -cursor_name left_ptr &

# Disable power management
xset -dpms &
xset s off &

# Notifications
xfce4-notifyd &

# Network applet
nm-applet &

# Volume icon
volumeicon &

echo "OffTopic Linux ready - Press Super for Spotlight"
